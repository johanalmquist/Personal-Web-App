{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "files": {
    "includes": ["apps/**", "packages/**", "*.json", "*.jsonc", "turbo.json"],
    "experimentalScannerIgnores": ["**/node_modules/**", "**/dist/**", "**/.turbo/**", "**/build/**"]
  }
}
